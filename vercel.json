{
  "rewrites": [
    {
      "source": "/04-2026/gofigeeks/:path*\\.:ext",
      "destination": "/25-04-2026/:path*.:ext"
    },
    {
      "source": "/04-2026/gofigeeks/(.*)",
      "destination": "/25-04-2026/index.html"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist"
}